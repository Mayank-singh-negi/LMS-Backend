# Environment Configuration - COPY TO .env AND FILL IN YOUR VALUES

# ========================================
# OPENAI API CONFIGURATION
# ========================================

# ⚠️ IMPORTANT: Get your API key from https://platform.openai.com/account/api-keys
# ⚠️ KEEP THIS SECRET - Never commit to git!
# Create a key specifically for this project
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model selection (recommended: gpt-4o-mini for best value)
# Options: gpt-4o-mini (recommended), gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Logging level
LOG_LEVEL=info

# ========================================
# DATABASE CONFIGURATION
# ========================================

# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/elearning?retryWrites=true&w=majority

# ========================================
# JWT AUTHENTICATION
# ========================================

# 🔐 IMPORTANT: Generate strong random secrets for production!
# Run this command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# For development, you can use simple strings, but for production:
# - Must be at least 32 characters
# - Must be random and unique
# - Store in secure secret manager (AWS Secrets Manager, HashiCorp Vault, etc.)

JWT_SECRET=your-very-long-random-secret-key-at-least-32-chars-here-change-this-in-production
JWT_REFRESH_SECRET=your-very-long-random-refresh-secret-key-at-least-32-chars-here-change-this

# JWT expiration times
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server port
PORT=5000

# Environment
NODE_ENV=development
# Options: development, staging, production

# ========================================
# CLOUDINARY CONFIGURATION (Optional - for media uploads)
# ========================================

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ========================================
# REDIS CONFIGURATION (Optional - for caching)
# ========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-if-needed

# ========================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@learnovora.com

# ========================================
# AI MODULE SPECIFIC CONFIGURATION
# ========================================

# Rate limiting
AI_DOUBT_SOLVER_LIMIT=30         # requests per 15 minutes
AI_QUIZ_GENERATOR_LIMIT=10       # requests per hour

# Token limits (prevents runaway costs)
AI_MAX_TOKENS_DOUBT=1000
AI_MAX_TOKENS_QUIZ=2000

# Temperature settings (0 = deterministic, 1 = creative)
AI_DOUBT_TEMPERATURE=0.7
AI_QUIZ_TEMPERATURE=0.5

# Budget limits (in USD per month)
AI_STUDENT_BUDGET=15
AI_TEACHER_BUDGET=75
AI_ADMIN_BUDGET=999999

# ========================================
# MONITORING & ALERTS
# ========================================

# Daily cost threshold for alerts (in USD)
AI_DAILY_COST_ALERT=100

# Error rate threshold (0-1)
AI_ERROR_RATE_ALERT=0.05

# Response time threshold (in ms)
AI_RESPONSE_TIME_ALERT=5000

# ========================================
# OPTIONAL: STRIPE INTEGRATION
# ========================================

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ========================================
# OPTIONAL: AWS CONFIGURATION
# ========================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# ========================================
# CORS CONFIGURATION
# ========================================

CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com

# ========================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ========================================

# 1. SECURITY CHECKLIST
#    ✓ Never commit this file to git
#    ✓ Use strong, unique values for all secrets
#    ✓ Rotate API keys regularly (monthly recommended)
#    ✓ Store in secure secret manager (AWS Secrets Manager, etc.)
#    ✓ Different secrets for dev/staging/production
#    ✓ Enable API key expiration on OpenAI dashboard
#    ✓ Monitor API key usage and delete unused keys

# 2. OPENAI SETUP
#    ✓ Create project-specific API key
#    ✓ Set usage limits in OpenAI dashboard
#    ✓ Enable billing alerts at $5, $10, $20, $50, $100
#    ✓ Monitor usage at https://platform.openai.com/account/billing/overview
#    ✓ Review rate limits at https://platform.openai.com/account/rate-limits

# 3. DATABASE SETUP
#    ✓ Create dedicated MongoDB user (not root)
#    ✓ Restrict user to specific database
#    ✓ Enable IP whitelist in MongoDB Atlas
#    ✓ Use TLS/SSL for connection
#    ✓ Enable backups and auto-scaling

# 4. JWT SECRETS
#    ✓ Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    ✓ Store securely (not in git!)
#    ✓ Different secrets for different environments
#    ✓ Rotate secrets when compromised

# 5. LOGGING
#    ✓ Never log API keys or secrets
#    ✓ Enable structured logging
#    ✓ Ship logs to centralized logging service (ELK/Splunk)
#    ✓ Monitor error rates and set up alerts

# 6. MONITORING
#    ✓ Set up uptime monitoring
#    ✓ Create dashboard for API metrics
#    ✓ Set up alerts for high error rates
#    ✓ Monitor database performance
#    ✓ Track OpenAI API response times

# 7. BACKUP & DISASTER RECOVERY
#    ✓ Regular database backups (daily)
#    ✓ Test restore procedures
#    ✓ Document recovery procedures
#    ✓ Have rollback plan

# ========================================
# DEVELOPMENT ONLY - IGNORE FOR PRODUCTION
# ========================================

# Disable SSL verification (ONLY for development!)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Run in debug mode
# DEBUG=*

# ========================================
# QUICK SETUP GUIDE
# ========================================

# 1. Copy this file to .env
#    cp .env.example .env

# 2. Fill in required values:
#    - OPENAI_API_KEY (from https://platform.openai.com/account/api-keys)
#    - MONGO_URI (from MongoDB Atlas)
#    - JWT_SECRET (generate random value)
#    - Other optional values

# 3. Add .env to .gitignore
#    echo ".env" >> .gitignore

# 4. Start server
#    npm run dev

# 5. Test endpoints
#    See POSTMAN_GUIDE.md for examples

# ========================================
# TROUBLESHOOTING
# ========================================

# Issue: "OPENAI_API_KEY not set"
# Solution: Ensure OPENAI_API_KEY is in .env file

# Issue: MongoDB connection fails
# Solution: Verify MONGO_URI is correct (test in MongoDB Atlas)

# Issue: JWT errors
# Solution: Regenerate JWT_SECRET and JWT_REFRESH_SECRET

# Issue: Rate limiting too strict
# Solution: Adjust AI_DOUBT_SOLVER_LIMIT and AI_QUIZ_GENERATOR_LIMIT

# Issue: High costs
# Solution: Check AI_MAX_TOKENS_* and reduce if needed

